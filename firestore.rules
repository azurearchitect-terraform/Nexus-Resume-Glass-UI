rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Basic helper: Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Basic helper: Check if user is accessing their own data
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default deny for all other resources
    match /{document=**} {
      allow read, write: if false;
    }

    // User-specific data: Only the owner can access their own document and subcollections
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /resumeVersions/{versionId} {
        allow read, write: if isOwner(userId);
      }

      match /jobs/{jobId} {
        allow read, write: if isOwner(userId);
      }

      match /tokenUsage/{monthId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Analytics: Any signed-in user can read (if applicable)
    match /analytics/{docId} {
      allow read: if isSignedIn();
    }
  }
}
